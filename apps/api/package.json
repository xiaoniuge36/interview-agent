{
  "name": "@interview-agent/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @interview-agent/contracts build && prisma generate --schema prisma/schema",
    "dev": "nest start --watch",
    "prebuild": "pnpm --filter @interview-agent/contracts build && prisma generate --schema prisma/schema",
    "build": "nest build",
    "start": "node dist/main.js",
    "pretypecheck": "pnpm --filter @interview-agent/contracts build && prisma generate --schema prisma/schema",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "db:generate": "prisma generate --schema prisma/schema",
    "db:migrate": "prisma migrate dev --schema prisma/schema",
    "db:studio": "prisma studio --schema prisma/schema",
    "pretest": "pnpm --filter @interview-agent/contracts build && prisma generate --schema prisma/schema",
    "test": "jest --runInBand --passWithNoTests"
  },
  "dependencies": {
    "@interview-agent/contracts": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "jose": "^5.10.0",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.28",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.17.0",
    "jest": "^29.7.0",
    "prisma": "6.19.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
