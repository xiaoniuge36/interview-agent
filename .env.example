# Local full-stack defaults only. Copy to .env and rotate every change-me value.
NODE_ENV=development
IMAGE_TAG=local

# PostgreSQL / pgvector
POSTGRES_DB=interview_agent
POSTGRES_USER=interview_agent
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://interview_agent:change-me-local-postgres@localhost:5432/interview_agent?schema=public

# Redis
REDIS_PASSWORD=change-me-local-redis
REDIS_HOST_PORT=6379
REDIS_URL=redis://:change-me-local-redis@localhost:6379
REDIS_REQUIRED=false

# MinIO
MINIO_ROOT_USER=interview-agent
MINIO_ROOT_PASSWORD=change-me-local-minio-password
MINIO_BUCKET=interview-agent-assets
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=interview-agent
MINIO_SECRET_KEY=change-me-in-local-environment
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Product API
API_HOST=0.0.0.0
API_PORT=3001
API_HOST_PORT=3001
API_BODY_LIMIT=1mb
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002
API_SWAGGER_ENABLED=true
API_THROTTLE_TTL_MS=60000
API_THROTTLE_LIMIT=120
AUTH_MODE=jwt_hs256
JWT_SECRET=dev-only-change-me-at-least-32-characters
JWT_ISSUER=interview-agent
JWT_AUDIENCE=interview-agent-web
OIDC_ISSUER_URL=https://identity.example.com/
OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
OIDC_AUDIENCE=interview-agent-web
AGENT_RUNTIME_URL=http://localhost:8000
AGENT_RUNTIME_TIMEOUT_MS=8000
AGENT_RUNTIME_MAX_ATTEMPTS=2
AGENT_RUNTIME_RETRY_BASE_MS=250
AGENT_RUNTIME_FALLBACK_ENABLED=true
INTERVIEW_COMMAND_LEASE_MS=360000
INTERNAL_AGENT_TOKEN=dev-internal-agent-token-change-me

# Agent Runtime
RUNTIME_HOST_PORT=8000
RUNTIME_BODY_LIMIT_BYTES=1048576
RUNTIME_LOG_LEVEL=INFO

# Frontend authentication
WEB_HOST_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Interview Agent
NEXT_PUBLIC_AUTH_MODE=development
NEXT_PUBLIC_USER_AUTH_MODE=local
NEXT_PUBLIC_OIDC_AUTHORITY=https://identity.example.com/
NEXT_PUBLIC_OIDC_CLIENT_ID=interview-agent-web
NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_OIDC_SCOPE=openid profile email

# Admin Console
ADMIN_HOST_PORT=3002
NEXT_PUBLIC_ADMIN_OIDC_CLIENT_ID=interview-agent-admin
NEXT_PUBLIC_ADMIN_OIDC_REDIRECT_URI=http://localhost:3002/auth/callback
NEXT_PUBLIC_ADMIN_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3002

# Observability
PHOENIX_HOST_PORT=6006
PHOENIX_GRPC_HOST_PORT=4317
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
PHOENIX_UI_URL=http://localhost:6006
