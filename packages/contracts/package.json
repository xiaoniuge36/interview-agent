{
  "name": "@interview-agent/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "pretest": "pnpm build",
    "test": "node --test dist/**/*.test.js",
    "generate:runtime": "tsx scripts/generate-runtime-schema.ts",
    "check:runtime": "tsx scripts/generate-runtime-schema.ts --check"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "tsx": "^4.20.3",
    "@types/node": "^22.17.0"
  }
}
